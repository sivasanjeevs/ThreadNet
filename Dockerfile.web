FROM node:20-bookworm AS build

WORKDIR /app

# --- Build user UI ---
COPY user-frontend/package*.json ./user-frontend/
RUN cd user-frontend && npm ci
COPY user-frontend ./user-frontend

# --- Build admin UI ---
COPY admin-frontend/package*.json ./admin-frontend/
RUN cd admin-frontend && npm ci
COPY admin-frontend ./admin-frontend

# Shared assets (logo).
COPY assets ./assets

# Build both UIs
RUN cd user-frontend && npm run build
RUN cd admin-frontend && npm run build

FROM nginx:1.27-alpine

COPY nginx/default.conf /etc/nginx/conf.d/default.conf

COPY --from=build /app/user-frontend/dist/ /usr/share/nginx/html/user/
COPY --from=build /app/admin-frontend/dist/ /usr/share/nginx/html/admin/

EXPOSE 80

